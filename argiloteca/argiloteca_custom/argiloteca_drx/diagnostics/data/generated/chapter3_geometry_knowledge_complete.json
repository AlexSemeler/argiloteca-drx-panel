        "source_full_title": "Diffraction I: Geometry",
        "source_id": "diffraction_geometry_chapter3_pdf",
        "table": null
      },
      "target": "d_spacing_calculation"
    },
    {
      "calculation": "two_theta = 2 * asin(lambda / (2*d))",
      "conditions": [
        {
          "feature": "lambda/(2*d)",
          "operator": "<=",
          "value": 1
        }
      ],
      "outputs": [
        "two_theta_degree"
      ],
